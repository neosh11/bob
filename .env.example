# Server network binding
BOB_HOST=0.0.0.0
BOB_PORT=4000

# Allowed frontend origin
BOB_WEB_ORIGIN=http://localhost:5173
# Optional comma-separated hostname prefixes. When set, only origins whose hostname
# starts with one of these prefixes are allowed (for example: 100 or 192.168).
# Numeric prefixes are matched as IPv4 prefixes only (100 -> 100.x.x.x), not domain names.
# Wildcards are accepted as suffix markers (100* -> 100).
BOB_WEB_ORIGIN_HOST_PREFIXES=

# Persistent storage
BOB_DB_PATH=apps/server/data/bob.sqlite

# Auth settings
BOB_JWT_SECRET=replace-with-a-long-secret-value
BOB_JWT_TTL=7d
BOB_COOKIE_NAME=bob_session
BOB_SHARED_PASSWORD=replace-with-a-long-shared-password

# Comma-separated absolute or relative paths users may run tasks in
BOB_WORKSPACES=/Users/neoshsheikh/Documents/github/bob

# Agent provider
# auto: use command when BOB_AGENT_COMMAND is set, otherwise mock
# command: require BOB_AGENT_COMMAND
# mock: deterministic local fallback
BOB_AGENT_MODE=auto
BOB_SESSIONS_BACKEND=app-server
BOB_CODEX_BIN=codex
BOB_CODEX_APP_SERVER_LISTEN=ws://127.0.0.1:8787
BOB_CODEX_APPROVAL_POLICY=never
BOB_CODEX_SANDBOX_MODE=danger-full-access
BOB_CODEX_MODEL=gpt-5.3-codex
BOB_CODEX_REASONING_EFFORT=medium
BOB_AGENT_HISTORY_WINDOW=12
BOB_MAX_CONCURRENT_RUNS=2

# Example command placeholders: {{prompt}}, {{latestPrompt}}, {{history}}, {{workspace}}, {{sessionId}}, {{runId}}, {{model}}, {{reasoningEffort}}
# BOB_AGENT_COMMAND=codex exec -m "{{model}}" -c model_reasoning_effort="{{reasoningEffort}}" --output-last-message "/tmp/bob-last-{{runId}}.txt" -C "{{workspace}}" "{{prompt}}" >/dev/null && cat "/tmp/bob-last-{{runId}}.txt"

# API hardening
BOB_RATE_LIMIT_WINDOW_MS=60000
BOB_RATE_LIMIT_MAX_REQUESTS=120
BOB_AUTH_RATE_LIMIT_MAX_REQUESTS=20
